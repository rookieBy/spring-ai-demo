<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <Property name="server.port">38010</Property>
        <Property name="server.log.path">/data/www/wifiin/logs/ws</Property>
    </Properties>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="[%-level-newsay-ai] %d{yyyy/MM/dd,HH:mm:ss.SSS}|%m%n"/>
            <ThresholdFilter level="${spring:server.log.console.level}" onMatch="ACCEPT" onMismatch="DENY"/>
        </Console>
        <RollingFile name="RollingFile"
                     fileName="${spring:server.log.path}/newsay-ai-${spring:server.port}.log"
                     filePattern="${spring:server.log.path}/newsay-ai-${spring:server.port}.log.%d{yyyy-MM-dd}.gz">
            <PatternLayout pattern="[%-level-newsay-ai] %d{yyyy/MM/dd,HH:mm:ss.SSS}|%m%n"/>
            <ThresholdFilter level="${spring:server.log.file.level}" onMatch="ACCEPT" onMismatch="DENY"/>
            <Policies>
                <TimeBasedTriggeringPolicy modulate="true" interval="1"/>
            </Policies>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Logger name="com.wifiin" level="${spring:server.log.file.level}" additivity="false">
            <appender-ref ref="RollingFile"/>
        </Logger>
        <Root level="${spring:server.log.console.level}">
            <appender-ref ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
