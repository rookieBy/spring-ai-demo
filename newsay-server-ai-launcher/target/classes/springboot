#!/bin/bash

# JVM Configuration
JAVA_OPTS="-Xms512m -Xmx1024m -XX:+UseG1GC"

# Server Configuration
SERVER_PORT=8080
LOG_DIR="/data/www/logs/ws"
APP_NAME="newsay-server-ai"

# JAR File
JAR_FILE="${APP_NAME}-1.0.0.jar"

# Paths
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAR_PATH="${BIN_DIR}/${JAR_FILE}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

check_pid() {
    if [ -f "${BIN_DIR}/${APP_NAME}.pid" ]; then
        PID=$(cat "${BIN_DIR}/${APP_NAME}.pid")
        if ps -p ${PID} > /dev/null 2>&1; then
            return 0
        else
            rm -f "${BIN_DIR}/${APP_NAME}.pid"
            return 1
        fi
    fi
    return 1
}

start() {
    if check_pid; then
        log_warn "${APP_NAME} is already running (PID: ${PID})"
        return 1
    fi

    if [ ! -f "${JAR_PATH}" ]; then
        log_error "JAR file not found: ${JAR_PATH}"
        return 1
    fi

    log_info "Starting ${APP_NAME}..."

    # Create log directory if not exists
    if [ ! -d "${LOG_DIR}" ]; then
        mkdir -p "${LOG_DIR}"
    fi

    nohup java ${JAVA_OPTS} -jar "${JAR_PATH}" \
        --server.port=${SERVER_PORT} \
        --logging.file.path="${LOG_DIR}" \
        > /dev/null 2>&1 &

    echo $! > "${BIN_DIR}/${APP_NAME}.pid"

    sleep 2

    if check_pid; then
        log_info "${APP_NAME} started successfully (PID: ${PID})"
    else
        log_error "Failed to start ${APP_NAME}"
        rm -f "${BIN_DIR}/${APP_NAME}.pid"
        return 1
    fi
}

stop() {
    if ! check_pid; then
        log_warn "${APP_NAME} is not running"
        return 1
    fi

    log_info "Stopping ${APP_NAME} (PID: ${PID})..."

    kill ${PID}

    for i in {1..30}; do
        if ! ps -p ${PID} > /dev/null 2>&1; then
            rm -f "${BIN_DIR}/${APP_NAME}.pid"
            log_info "${APP_NAME} stopped successfully"
            return 0
        fi
        sleep 1
    done

    log_warn "Force killing ${APP_NAME}..."
    kill -9 ${PID}
    rm -f "${BIN_DIR}/${APP_NAME}.pid"
    log_info "${APP_NAME} killed"
}

restart() {
    stop
    sleep 2
    start
}

status() {
    if check_pid; then
        log_info "${APP_NAME} is running (PID: ${PID})"
    else
        log_warn "${APP_NAME} is not running"
    fi
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        restart
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
